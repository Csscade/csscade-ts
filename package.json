{
  "name": "csscade",
  "version": "1.0.0",
  "private": true,
  "description": "Csscade website",
  "author": "Manon Carbonnel",
  "license": "MIT",
  "type": "module",
  "browserslist": [
    "defaults",
    "not op_mini all",
    "not and_uc > 0",
    "not kaios > 0"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "serve out -l 3000",
    "lint": "biome check",
    "format": "biome format --write",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:arch-unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:storybook": "vitest run --project storybook",
    "test:ui": "vitest run --project storybook && playwright test tests/a11y.spec.ts",
    "test:lighthouse": "playwright test tests/lighthouse.spec.ts",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@next/mdx": "^16.2.9",
    "@shikijs/rehype": "^4.3.0",
    "@syenchuk/remark-abbr": "^1.0.1",
    "@types/mdx": "^2.0.14",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-deflist": "^1.0.0",
    "remark-emoji": "^5.0.2",
    "remark-flexible-markers": "^1.3.5",
    "remark-ins": "^1.2.5",
    "remark-smartypants": "^3.0.2",
    "remark-supersub": "^1.0.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "lighthouse": "^13.4.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm-table": "^2.0.0",
    "playwright": "^1.61.1",
    "playwright-lighthouse": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "safe-stable-stringify": "^2.5.0",
    "serve": "^14.2.6",
    "shiki": "^4.3.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.9"
  },
  "workspaces": [
    "src/*"
  ]
}
